{
  "description": "Security-focused web server configuration corpus for local static analyzer validation.",
  "safety": "All configs are local fixtures. They do not contain secrets and do not target live third-party infrastructure.",
  "cases": [
    {
      "id": "nginx-detectify-off-by-slash-alias",
      "server_type": "nginx",
      "profile": "vulnerable",
      "source": "Detectify vulnerable-nginx and alias traversal research",
      "source_url": "https://github.com/detectify/vulnerable-nginx",
      "license": "No obvious repository license was used for copying; this is a small synthetic-derived fixture based on the public vulnerability pattern.",
      "description": "Alias/proxy path shape inspired by common Nginx off-by-slash and alias traversal examples.",
      "entrypoint": "nginx/vulnerable/detectify-off-by-slash-alias.conf",
      "synthetic_or_original": "synthetic-derived",
      "notes_about_modifications": "Domains, paths, and upstreams are placeholders. The fixture is minimized to exercise webconf-audit rule IDs rather than reproduce a full vulnerable app.",
      "references": [
        "https://blog.detectify.com/industry-insights/common-nginx-misconfigurations-that-leave-your-web-server-ope-to-attack/",
        "https://github.com/detectify/vulnerable-nginx",
        "https://github.com/tkmru/nginx-alias-traversal-sample"
      ],
      "coverage_notes": [
        "webconf-audit currently detects the location-slash/alias-no-slash variant as nginx.alias_without_trailing_slash.",
        "The classic Gixy alias_traversal shape is kept as a reference gap in the documentation."
      ],
      "expected_findings": [
        {
          "rule_id": "nginx.alias_without_trailing_slash",
          "severity": "low",
          "title_contains": "Alias",
          "location_contains": "detectify-off-by-slash-alias.conf"
        },
        {
          "rule_id": "nginx.default_server_not_rejecting_unknown_hosts",
          "severity": "low",
          "location_contains": "detectify-off-by-slash-alias.conf"
        },
        {
          "rule_id": "nginx.proxy_missing_source_ip_headers",
          "severity": "low",
          "location_contains": "detectify-off-by-slash-alias.conf"
        },
        {
          "rule_id": "nginx.sensitive_location_missing_ip_filter",
          "severity": "low",
          "location_contains": "detectify-off-by-slash-alias.conf"
        }
      ]
    },
