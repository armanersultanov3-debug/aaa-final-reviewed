<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <!-- This is the web.config of a deeper-nested child application at
         "Default Web Site/api/sub".  It does not itself enable directory
         browsing.  Because the parent <location> has
         inheritInChildApplications=false, the unsafe setting must NOT
         leak into this scope.  No directoryBrowse finding should be
         emitted against this file. -->
    <system.webServer>
        <httpProtocol>
            <customHeaders>
                <add name="X-Content-Type-Options" value="nosniff" />
            </customHeaders>
        </httpProtocol>
    </system.webServer>
</configuration>
