<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <system.webServer>
        <handlers accessPolicy="Read, Script">
            <remove name="MachineCgi" path="*.cgi" verb="*" />
            <add
                name="ApiHandler"
                path="api/*"
                verb="GET"
                modules="ManagedPipelineHandler"
            />
        </handlers>
    </system.webServer>
</configuration>
