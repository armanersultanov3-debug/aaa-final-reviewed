<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <system.webServer>
        <handlers accessPolicy="Read, Write, Script">
            <add
                name="MachineCgi"
                path="*.cgi"
                verb="*"
                modules="CgiModule"
            />
            <add
                name="StaticFile"
                path="*"
                verb="GET,HEAD"
                modules="StaticFileModule"
            />
        </handlers>
    </system.webServer>
</configuration>
