<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <!-- web.config overrides the unsafe applicationHost setting at the
         same location path.  The effective view must show enabled=false
         and no directory_browse finding should be emitted. -->
    <location path="Default Web Site/api">
        <system.webServer>
            <directoryBrowse enabled="false" />
        </system.webServer>
    </location>
</configuration>
