<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <!-- applicationHost.config: directoryBrowse turned ON for /api,
         which is unsafe.  web.config at the same location overrides it
         to OFF, and that override should win in the effective view. -->
    <location path="Default Web Site/api">
        <system.webServer>
            <directoryBrowse enabled="true" />
        </system.webServer>
    </location>
</configuration>
