<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <system.web>
        <!-- web.config overrides machine.config: turns off HttpOnly and
             requireSSL for cookies.  The effective view must reflect this
             unsafe override and the rule must point at web.config. -->
        <httpCookies httpOnlyCookies="false" requireSSL="false" />
    </system.web>
</configuration>
