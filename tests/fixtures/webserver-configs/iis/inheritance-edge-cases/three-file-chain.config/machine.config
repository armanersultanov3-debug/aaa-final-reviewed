<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <configSections>
        <sectionGroup name="system.web">
            <section name="httpCookies" />
        </sectionGroup>
    </configSections>
    <system.web>
        <httpCookies httpOnlyCookies="true" requireSSL="true" />
        <deployment retail="true" />
    </system.web>
</configuration>
