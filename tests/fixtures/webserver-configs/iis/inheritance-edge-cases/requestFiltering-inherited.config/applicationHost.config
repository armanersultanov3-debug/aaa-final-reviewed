<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <system.webServer>
        <security>
            <requestFiltering removeServerHeader="false">
                <requestLimits
                    maxAllowedContentLength="4194304"
                    maxUrl="8192"
                />
                <fileExtensions allowUnlisted="true">
                    <add fileExtension=".config" allowed="false" />
                </fileExtensions>
            </requestFiltering>
        </security>
    </system.webServer>
</configuration>
