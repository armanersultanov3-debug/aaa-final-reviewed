<?xml version="1.0" encoding="utf-8"?>
<!--
    CIS Microsoft IIS 10 Benchmark v1.2.1 §4.2 / §4.3 / §4.7 anti-pattern:
    requestFiltering left in a maximally-permissive state. Double-escape
    requests and high-bit characters allowed; unlisted file extensions
    allowed; ISAPI / CGI restrictions allow unlisted; absurdly large
    URL / query / body limits; native Server header removal disabled.
-->
<configuration>
    <system.webServer>
        <security>
            <requestFiltering allowDoubleEscaping="true"
                              allowHighBitCharacters="true"
                              removeServerHeader="false">
                <requestLimits maxAllowedContentLength="4294967295"
                               maxUrl="1048576"
                               maxQueryString="262144" />
                <fileExtensions allowUnlisted="true" />
            </requestFiltering>
            <isapiCgiRestriction allowUnlisted="true" />
        </security>
    </system.webServer>
</configuration>
