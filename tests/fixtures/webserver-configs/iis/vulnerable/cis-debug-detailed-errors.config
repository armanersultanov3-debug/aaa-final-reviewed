<?xml version="1.0" encoding="utf-8"?>
<!--
    CIS Microsoft IIS 10 Benchmark v1.2.1 §3.1, §3.7, §3.8 anti-patterns
    surfaced together: debug enabled, detailed errors visible, custom
    errors off, and ASP.NET trace enabled. Each of these would leak
    server-side detail to public clients on a misconfigured site.
-->
<configuration>
    <system.webServer>
        <httpErrors errorMode="Detailed" />
        <directoryBrowse enabled="true" />
    </system.webServer>
    <system.web>
        <compilation debug="true" />
        <customErrors mode="Off" />
        <trace enabled="true" />
        <deployment retail="false" />
    </system.web>
</configuration>
