<?xml version="1.0" encoding="utf-8"?>
<!--
    CIS Microsoft IIS 10 Benchmark v1.2.1 §1.4 / §2.1 / §2.5 / §2.6 / §2.7
    anti-pattern: anonymous authentication enabled with a specific
    privileged user, basic authentication enabled without an SSL
    requirement, forms authentication without requireSSL, weak
    machineKey validation algorithm, and an "allow all anonymous"
    URL authorization rule.
-->
<configuration>
    <system.webServer>
        <security>
            <authentication>
                <anonymousAuthentication enabled="true" userName="DOMAIN\AdminAccount" />
                <basicAuthentication enabled="true" />
            </authentication>
            <authorization>
                <add accessType="Allow" users="?" />
            </authorization>
        </security>
    </system.webServer>
    <system.web>
        <authentication mode="Forms">
            <forms requireSSL="false" cookieless="UseUri" protection="None" />
            <credentials passwordFormat="Clear">
                <user name="alice" password="hunter2" />
            </credentials>
        </authentication>
        <machineKey validation="MD5" />
    </system.web>
</configuration>
