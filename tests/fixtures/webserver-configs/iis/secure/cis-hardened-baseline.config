<?xml version="1.0" encoding="utf-8"?>
<!--
    CIS Microsoft IIS 10 Benchmark v1.2.1 hardened baseline: anonymous
    authentication disabled, debug / detailed errors / trace disabled,
    HSTS configured, SSL required, request filtering tightened, server
    header removed, retail mode enabled. The remaining medium findings
    are operator-context defaults that do not constitute high/critical
    risk; the secure-baseline test only asserts no high/critical
    findings.
-->
<configuration>
    <system.webServer>
        <httpProtocol>
            <customHeaders>
                <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
                <add name="X-Content-Type-Options" value="nosniff" />
                <add name="X-Frame-Options" value="DENY" />
                <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
            </customHeaders>
        </httpProtocol>
        <httpErrors errorMode="Custom" existingResponse="Replace" />
        <directoryBrowse enabled="false" />
        <httpLogging dontLog="false" />
        <security>
            <access sslFlags="Ssl, SslRequireCert" />
            <authentication>
                <anonymousAuthentication enabled="false" />
                <basicAuthentication enabled="false" />
            </authentication>
            <authorization>
                <clear />
                <add accessType="Allow" roles="Administrators" />
            </authorization>
            <requestFiltering allowDoubleEscaping="false"
                              allowHighBitCharacters="false"
                              removeServerHeader="true">
                <requestLimits maxAllowedContentLength="102400"
                               maxUrl="4096"
                               maxQueryString="2048" />
                <fileExtensions allowUnlisted="false" />
            </requestFiltering>
            <isapiCgiRestriction allowUnlisted="false" />
        </security>
    </system.webServer>
    <system.web>
        <compilation debug="false" />
        <customErrors mode="On" defaultRedirect="/error" />
        <trace enabled="false" />
        <deployment retail="true" />
        <httpRuntime enableVersionHeader="false" maxRequestLength="102400" />
        <httpCookies httpOnlyCookies="true" requireSSL="true" />
        <trust level="Medium" />
        <machineKey validation="HMACSHA256" />
        <authentication mode="Forms">
            <forms requireSSL="true" cookieless="UseCookies" protection="All" />
        </authentication>
    </system.web>
</configuration>
