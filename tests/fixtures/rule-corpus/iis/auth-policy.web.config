<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <security>
      <access sslFlags="None" />
      <authentication>
        <anonymousAuthentication enabled="true" userName="IUSR_Specific" />
        <basicAuthentication enabled="true" />
      </authentication>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="12345" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
