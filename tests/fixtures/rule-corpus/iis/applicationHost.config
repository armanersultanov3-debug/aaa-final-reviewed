<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.applicationHost>
    <applicationPools>
      <add name="SharedPool">
        <processModel identityType="NetworkService" />
      </add>
    </applicationPools>
    <sites>
      <site name="Default Web Site" id="1">
        <application path="/" applicationPool="SharedPool">
          <virtualDirectory path="/" physicalPath="tests/fixtures/rule-corpus/iis/wwwroot" />
        </application>
        <bindings>
          <binding protocol="http" bindingInformation="*:80:" />
        </bindings>
      </site>
      <site name="Second Site" id="2">
        <application path="/" applicationPool="SharedPool">
          <virtualDirectory path="/" physicalPath="tests/fixtures/rule-corpus/iis/wwwroot2" />
        </application>
        <bindings>
          <binding protocol="http" bindingInformation="*:8080:" />
        </bindings>
      </site>
    </sites>
    <isapiCgiRestriction notListedIsapisAllowed="true" notListedCgisAllowed="true" />
  </system.applicationHost>
  <system.webServer>
    <directoryBrowse enabled="true" />
    <httpErrors errorMode="Detailed" />
    <asp scriptErrorSentToBrowser="true" />
    <security>
      <access sslFlags="None" />
      <authorization>
        <add accessType="Allow" users="*" />
      </authorization>
      <requestFiltering allowDoubleEscaping="true" allowHighBitCharacters="true" removeServerHeader="false">
        <requestLimits maxAllowedContentLength="999999999" maxUrl="99999" maxQueryString="99999" />
        <fileExtensions allowUnlisted="true" />
      </requestFiltering>
    </security>
    <handlers accessPolicy="Read, Script, Execute, Write">
      <add name="CGI-exe" path="*.exe" verb="*" modules="CgiModule" scriptProcessor="C:\Windows\System32\cmd.exe" resourceType="File" />
    </handlers>
    <modules>
      <add name="WebDAVModule" />
    </modules>
    <httpProtocol>
      <customHeaders>
        <add name="X-Powered-By" value="ASP.NET" />
        <add name="Server" value="Microsoft-IIS/10.0" />
        <add name="Strict-Transport-Security" value="max-age=100" />
        <add name="Content-Security-Policy" value="default-src * 'unsafe-inline'" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
  <system.web>
    <compilation debug="true" />
    <customErrors mode="Off" />
    <trace enabled="true" />
    <httpRuntime enableVersionHeader="true" />
    <authentication mode="Forms">
      <forms requireSSL="false" protection="None">
        <credentials passwordFormat="Clear">
          <user name="admin" password="password" />
        </credentials>
      </forms>
    </authentication>
    <authorization>
      <allow users="*" />
    </authorization>
    <sessionState cookieless="UseUri" />
    <httpCookies httpOnlyCookies="false" requireSSL="false" />
    <deployment retail="false" />
    <trust level="Full" />
    <machineKey validation="SHA1" compatibilityMode="Framework45" />
  </system.web>
</configuration>
